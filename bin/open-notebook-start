#!/usr/bin/env bash
set -euo pipefail
PATH="$HOME/bin:$PATH"

service_dir="${OPEN_NOTEBOOK_HOME:-$HOME/services/open-notebook}"
compose_file="$service_dir/docker-compose.yml"
idle_watch="$HOME/bin/open-notebook-idle-watch"
kokoro_configure="$HOME/bin/open-notebook-configure-kokoro"
embeddings_configure="$HOME/bin/open-notebook-configure-embeddings"
okf_notes_configure="$HOME/bin/open-notebook-configure-okf-notes"
idle_watch_pid="/tmp/open-notebook-idle-watch.pid"
local_url="http://127.0.0.1:8502"
local_api_url="http://127.0.0.1:5055"
local_tts_url="http://127.0.0.1:8880"
local_embeddinggemma_url="http://127.0.0.1:8081"
local_embedding_math_url="http://127.0.0.1:8082"
local_embedding_code_url="http://127.0.0.1:8083"
compose_cmd=()

require_command() {
  if ! command -v "$1" >/dev/null 2>&1; then
    printf 'Missing required command: %s\n' "$1" >&2
    exit 1
  fi
}

detect_compose() {
  if docker compose version >/dev/null 2>&1; then
    compose_cmd=(docker compose)
  elif command -v docker-compose >/dev/null 2>&1; then
    compose_cmd=(docker-compose)
  else
    printf 'Missing Docker Compose. Install the Docker Compose v2 plugin or docker-compose.\n' >&2
    exit 1
  fi
}

tailscale_url() {
  local dns_name
  dns_name="$(tailscale status --json 2>/dev/null | sed -n 's/.*"DNSName": *"\([^"]*\)".*/\1/p' | head -n 1)"
  if [ -n "$dns_name" ]; then
    printf 'https://%s/\n' "${dns_name%.}"
  else
    printf 'https://<this-machine>.<tailnet>.ts.net/\n'
  fi
}

tailscale_api_url() {
  local ui_url
  ui_url="$(tailscale_url)"
  printf '%s:5055/\n' "${ui_url%/}"
}

wait_embedding_endpoint() {
  local label="$1"
  local url="$2"
  local model="$3"
  local payload
  payload="$(printf '{"input":"Open Notebook embedding health check","model":"%s","encoding_format":"float"}' "$model")"

  printf 'Waiting for %s at %s/v1/embeddings' "$label" "$url"
  for _ in $(seq 1 300); do
    if curl -fsS -X POST "$url/v1/embeddings" -H 'Content-Type: application/json' -d "$payload" >/dev/null 2>&1; then
      printf '\n'
      return 0
    fi
    printf '.'
    sleep 2
  done

  printf '\n%s did not respond within 600 seconds. If this is a gated Hugging Face model, set HF_TOKEN in %s.\n' "$label" "$service_dir/.env" >&2
  "${compose_cmd[@]}" -f "$compose_file" ps >&2 || true
  exit 1
}

require_command docker
require_command tailscale
require_command curl
require_command timeout
detect_compose

if [ ! -f "$compose_file" ]; then
  printf 'Compose file not found: %s\n' "$compose_file" >&2
  exit 1
fi

"${compose_cmd[@]}" -f "$compose_file" up -d

printf 'Waiting for Open Notebook at %s' "$local_url"
for _ in $(seq 1 60); do
  if curl -fsS "$local_url" >/dev/null 2>&1; then
    printf '\n'
    break
  fi
  printf '.'
  sleep 2
done

if ! curl -fsS "$local_url" >/dev/null 2>&1; then
  printf '\nOpen Notebook did not respond within 120 seconds.\n' >&2
  "${compose_cmd[@]}" -f "$compose_file" ps >&2 || true
  exit 1
fi

if ! curl -fsS "$local_api_url/health" >/dev/null 2>&1; then
  printf 'Open Notebook API did not respond at %s/health.\n' "$local_api_url" >&2
  "${compose_cmd[@]}" -f "$compose_file" ps >&2 || true
  exit 1
fi

printf 'Waiting for Kokoro TTS at %s/v1/models' "$local_tts_url"
for _ in $(seq 1 120); do
  if curl -fsS "$local_tts_url/v1/models" >/dev/null 2>&1; then
    printf '\n'
    break
  fi
  printf '.'
  sleep 2
done

if ! curl -fsS "$local_tts_url/v1/models" >/dev/null 2>&1; then
  printf '\nKokoro TTS did not respond within 240 seconds.\n' >&2
  "${compose_cmd[@]}" -f "$compose_file" ps >&2 || true
  exit 1
fi

if [ -x "$kokoro_configure" ]; then
  "$kokoro_configure"
fi

wait_embedding_endpoint "EmbeddingGemma" "$local_embeddinggemma_url" "google/embeddinggemma-300m"
wait_embedding_endpoint "Math embeddings" "$local_embedding_math_url" "math-similarity/Bert-MLM_arXiv-MP-class_zbMath"
wait_embedding_endpoint "CodeBERT embeddings" "$local_embedding_code_url" "microsoft/codebert-base"

if [ -x "$embeddings_configure" ]; then
  "$embeddings_configure"
fi

if [ -x "$okf_notes_configure" ]; then
  "$okf_notes_configure"
fi

if ! serve_output="$(timeout 30 tailscale serve --bg --yes --https=443 "$local_url" 2>&1)"; then
  printf 'Failed to configure Tailscale Serve for the Open Notebook UI.\n' >&2
  if [ -n "$serve_output" ]; then
    printf '%s\n' "$serve_output" >&2
  fi
  "${compose_cmd[@]}" -f "$compose_file" down >&2 || true
  exit 1
fi

if ! serve_output="$(timeout 30 tailscale serve --bg --yes --https=5055 "$local_api_url" 2>&1)"; then
  printf 'Failed to configure Tailscale Serve for the Open Notebook API.\n' >&2
  if [ -n "$serve_output" ]; then
    printf '%s\n' "$serve_output" >&2
  fi
  "${compose_cmd[@]}" -f "$compose_file" down >&2 || true
  exit 1
fi

if [ -x "$idle_watch" ]; then
  if [ -f "$idle_watch_pid" ] && kill -0 "$(cat "$idle_watch_pid")" >/dev/null 2>&1; then
    :
  else
    nohup "$idle_watch" >/tmp/open-notebook-idle-watch.log 2>&1 &
    printf '%s\n' "$!" >"$idle_watch_pid"
  fi
fi

printf 'Open Notebook is running.\n'
printf 'Local: %s\n' "$local_url"
printf 'Local API: %s\n' "$local_api_url"
printf 'Local Kokoro TTS: %s\n' "$local_tts_url"
printf 'Local EmbeddingGemma: %s\n' "$local_embeddinggemma_url"
printf 'Local math embeddings: %s\n' "$local_embedding_math_url"
printf 'Local CodeBERT embeddings: %s\n' "$local_embedding_code_url"
printf 'Open Notebook TTS base URL: http://kokoro:8880/v1\n'
printf 'Kokoro voices: af_bella, af_sky, af_bella+af_sky\n'
printf 'Open Notebook embedding base URLs: http://embeddinggemma:80/v1, http://embedding-math:80/v1, http://embedding-code:8000/v1\n'
printf 'Embedding models: google/embeddinggemma-300m, math-similarity/Bert-MLM_arXiv-MP-class_zbMath, microsoft/codebert-base\n'
printf 'Tailscale: %s\n' "$(tailscale_url)"
printf 'Tailscale API: %s\n' "$(tailscale_api_url)"
printf 'Idle watcher: stops containers after 30 minutes without Docker network I/O changes.\n'
