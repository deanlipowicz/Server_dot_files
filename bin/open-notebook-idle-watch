#!/usr/bin/env bash
set -euo pipefail
PATH="$HOME/bin:$PATH"

service_dir="${OPEN_NOTEBOOK_HOME:-$HOME/services/open-notebook}"
compose_file="$service_dir/docker-compose.yml"
idle_seconds="${OPEN_NOTEBOOK_IDLE_SECONDS:-1800}"
sample_seconds="${OPEN_NOTEBOOK_SAMPLE_SECONDS:-60}"
stop_cmd="$HOME/bin/open-notebook-stop"
compose_cmd=()

detect_compose() {
  if docker compose version >/dev/null 2>&1; then
    compose_cmd=(docker compose)
  elif command -v docker-compose >/dev/null 2>&1; then
    compose_cmd=(docker-compose)
  else
    printf 'Missing Docker Compose. Install the Docker Compose v2 plugin or docker-compose.\n' >&2
    exit 1
  fi
}

network_sample() {
  local ids
  ids="$("${compose_cmd[@]}" -f "$compose_file" ps -q 2>/dev/null | sort)"
  if [ -z "$ids" ]; then
    return 1
  fi
  docker container stats --no-stream --format '{{.ID}} {{.NetIO}}' $ids 2>/dev/null | sort
}

if [ ! -f "$compose_file" ]; then
  printf 'Compose file not found: %s\n' "$compose_file" >&2
  exit 1
fi

detect_compose
last_sample="$(network_sample || true)"
if [ -z "$last_sample" ]; then
  exit 0
fi
idle_elapsed=0

while sleep "$sample_seconds"; do
  current_sample="$(network_sample || true)"
  if [ -z "$current_sample" ]; then
    exit 0
  fi

  if [ "$current_sample" = "$last_sample" ]; then
    idle_elapsed=$((idle_elapsed + sample_seconds))
  else
    idle_elapsed=0
    last_sample="$current_sample"
  fi

  if [ "$idle_elapsed" -ge "$idle_seconds" ]; then
    if [ -x "$stop_cmd" ]; then
      "$stop_cmd"
    else
      "${compose_cmd[@]}" -f "$compose_file" down
    fi
    exit 0
  fi
done
