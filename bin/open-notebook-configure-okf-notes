#!/usr/bin/env python3
import json
import sys
import urllib.error
import urllib.request


API = "http://127.0.0.1:5055/api"
MARKER = "Open Knowledge Format"

OKF_DEFAULT_INSTRUCTIONS = """# INSTRUCTIONS

You are my learning assistant and you help me process and transform content so that I can extract durable notes and summaries from it.

# OUTPUT DEFAULTS

- Output only the requested content, without acknowledgements or extra chat.
- Default durable notes and summaries to Open Knowledge Format structure.
- Use Markdown with YAML frontmatter.
- Include `type` in every frontmatter block. Use `type: note` unless a more specific type is requested.
- Include useful `title`, `description`, `resource`, `tags`, and `timestamp` metadata when the information is known from the input or request.
- Keep one concept per note. If the input covers several separable concepts, either produce clearly separated note sections or state that the material should become multiple notes.
- Use ordinary Markdown links between related concepts, sources, and note IDs when available.
- Keep the body concise and source-linked.
- Separate observations, decisions, open questions, and next actions instead of mixing them in prose.
- Do not wrap the final note in a code fence.
"""

OKF_GENERAL_NOTE_PROMPT = """# SYSTEM ROLE
You are a research note assistant that converts source material into a durable Open Knowledge Format note.

# TASK
Analyze the provided content and write a general note or summary using this exact structure:

---
type: note
title: "<short descriptive title>"
description: "<one sentence description>"
resource: "<source title, URL, citation, or document ID when known>"
tags:
  - "<2-6 useful tags>"
timestamp: "<ISO 8601 date or datetime if known>"
---

# <Title>

## Summary
- Capture the central point and why it matters.
- Keep bullets concise and specific.

## Observations
- Record factual findings, definitions, claims, or methods from the source.
- Link to source, note, or insight IDs when available.

## Decisions
- Record only explicit decisions, recommendations, or settled conclusions.
- If there are none, write "None stated."

## Open Questions
- Record unresolved questions, assumptions to check, or unclear points.
- If there are none, write "None."

## Next Actions
- Record concrete follow-up actions for reading, analysis, coding, or writing.
- If there are none, write "None."

## Links
- Add Markdown links to related sources, notes, concepts, citations, or artifacts when available.

# OUTPUT RULES
- Output Markdown only.
- Do not include a code fence.
- Do not invent metadata. Omit optional metadata values only when genuinely unknown; keep `type` present.
- Keep one concept per note. If multiple concepts must be kept, separate them with second-level headings.
"""

SUMMARY_TRANSFORMATIONS = {
    "Simple Summary": OKF_GENERAL_NOTE_PROMPT,
    "Dense Summary": OKF_GENERAL_NOTE_PROMPT,
}

OKF_TRANSFORMATION = {
    "name": "OKF General Note",
    "title": "OKF General Note",
    "description": "Creates an Open Knowledge Format Markdown note with YAML frontmatter.",
    "prompt": OKF_GENERAL_NOTE_PROMPT,
    "apply_default": True,
}


def request(method, path, data=None):
    body = None
    headers = {"Accept": "application/json"}
    if data is not None:
        body = json.dumps(data).encode("utf-8")
        headers["Content-Type"] = "application/json"

    req = urllib.request.Request(
        f"{API}{path}", data=body, headers=headers, method=method
    )
    try:
        with urllib.request.urlopen(req, timeout=30) as response:
            payload = response.read()
    except urllib.error.HTTPError as exc:
        detail = exc.read().decode("utf-8", errors="replace")
        raise RuntimeError(f"{method} {path} failed: HTTP {exc.code}: {detail}") from exc

    if not payload:
        return None
    return json.loads(payload.decode("utf-8"))


def ensure_default_prompt():
    current = request("GET", "/transformations/default-prompt")
    existing = current.get("transformation_instructions", "") if current else ""
    if MARKER in existing and "`type`" in existing:
        print("Default transformation prompt already includes OKF instructions.")
        return

    request(
        "PUT",
        "/transformations/default-prompt",
        {"transformation_instructions": OKF_DEFAULT_INSTRUCTIONS},
    )
    print("Default transformation prompt configured for OKF notes.")


def find_by_name(transformations, name):
    for transformation in transformations:
        if transformation.get("name") == name:
            return transformation
    return None


def ensure_transformation(transformations, spec):
    existing = find_by_name(transformations, spec["name"])
    if not existing:
        created = request("POST", "/transformations", spec)
        print(f"Created transformation: {created['name']}")
        return created

    updates = {}
    for key in ("title", "description", "prompt", "apply_default"):
        if existing.get(key) != spec[key]:
            updates[key] = spec[key]

    if updates:
        updated = request("PUT", f"/transformations/{existing['id']}", updates)
        print(f"Updated transformation: {updated['name']}")
        return updated

    print(f"Transformation already configured: {existing['name']}")
    return existing


def ensure_summary_transformations(transformations):
    for name, prompt in SUMMARY_TRANSFORMATIONS.items():
        existing = find_by_name(transformations, name)
        if not existing:
            print(f"Summary transformation not found, skipping: {name}", file=sys.stderr)
            continue

        if MARKER in existing.get("prompt", "") and "`type`" in existing.get("prompt", ""):
            print(f"Summary transformation already OKF-configured: {name}")
            continue

        updates = {
            "description": f"{existing.get('description') or name}; outputs Open Knowledge Format Markdown.",
            "prompt": prompt,
            "apply_default": True,
        }
        request("PUT", f"/transformations/{existing['id']}", updates)
        print(f"Configured summary transformation for OKF output: {name}")


def main():
    ensure_default_prompt()
    transformations = request("GET", "/transformations")
    ensure_transformation(transformations, OKF_TRANSFORMATION)
    transformations = request("GET", "/transformations")
    ensure_summary_transformations(transformations)


if __name__ == "__main__":
    main()
