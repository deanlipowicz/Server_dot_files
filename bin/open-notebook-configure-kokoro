#!/usr/bin/env python3
import json
import sys
import urllib.error
import urllib.request


API = "http://127.0.0.1:5055/api"
NAME = "Local Kokoro TTS"
PROVIDER = "openai_compatible"
BASE_URL = "http://kokoro:8880/v1"
MODEL_NAME = "kokoro"
MODEL_TYPE = "text_to_speech"


def request(method, path, data=None):
    body = None
    headers = {"Accept": "application/json"}
    if data is not None:
        body = json.dumps(data).encode("utf-8")
        headers["Content-Type"] = "application/json"

    req = urllib.request.Request(
        f"{API}{path}", data=body, headers=headers, method=method
    )
    try:
        with urllib.request.urlopen(req, timeout=30) as response:
            payload = response.read()
    except urllib.error.HTTPError as exc:
        detail = exc.read().decode("utf-8", errors="replace")
        raise RuntimeError(f"{method} {path} failed: HTTP {exc.code}: {detail}") from exc

    if not payload:
        return None
    return json.loads(payload.decode("utf-8"))


def find_kokoro_credential(credentials):
    for credential in credentials:
        if (
            credential.get("provider") == PROVIDER
            and credential.get("base_url") == BASE_URL
        ):
            return credential
    for credential in credentials:
        if credential.get("name") == NAME and credential.get("provider") == PROVIDER:
            return credential
    return None


def ensure_credential():
    credentials = request("GET", f"/credentials?provider={PROVIDER}")
    credential = find_kokoro_credential(credentials)
    data = {
        "name": NAME,
        "provider": PROVIDER,
        "modalities": [MODEL_TYPE],
        "base_url": BASE_URL,
    }

    if credential:
        updates = {}
        if credential.get("name") != NAME:
            updates["name"] = NAME
        if credential.get("base_url") != BASE_URL:
            updates["base_url"] = BASE_URL
        if credential.get("modalities") != [MODEL_TYPE]:
            updates["modalities"] = [MODEL_TYPE]
        if updates:
            credential = request("PUT", f"/credentials/{credential['id']}", updates)
        return credential

    return request("POST", "/credentials", data)


def ensure_model(credential_id):
    models = request("GET", f"/models?type={MODEL_TYPE}")
    for model in models:
        if model.get("provider") == PROVIDER and model.get("name") == MODEL_NAME:
            if model.get("credential") == credential_id:
                return model
            print(
                "Kokoro TTS model exists but is linked to a different credential; "
                "leaving it unchanged.",
                file=sys.stderr,
            )
            return model

    return request(
        "POST",
        "/models",
        {
            "name": MODEL_NAME,
            "provider": PROVIDER,
            "type": MODEL_TYPE,
            "credential": credential_id,
        },
    )


def ensure_default_tts(model_id):
    defaults = request("GET", "/models/defaults")
    if defaults.get("default_text_to_speech_model"):
        return defaults

    defaults["default_text_to_speech_model"] = model_id
    return request("PUT", "/models/defaults", defaults)


def main():
    credential = ensure_credential()
    model = ensure_model(credential["id"])
    ensure_default_tts(model["id"])
    print(f"Kokoro credential: {credential['id']}")
    print(f"Kokoro TTS model: {model['id']}")
    print("Kokoro voices: af_bella, af_sky, af_bella+af_sky")


if __name__ == "__main__":
    main()
